@model IEnumerable<DoAnLapTrinhWeb.Models.Reservation>

@{
    var totalPending = (int)ViewBag.TotalPending;
}

<div class="notification-wrapper">
    <div class="topbar-icon" id="notificationBell">
        🔔@if (totalPending > 0)
        {
            <span class="notif-dot">@totalPending</span>
        }
    </div>

    <!-- Notification Dropdown -->
    <div class="notif-dropdown" id="notifDropdown">
        <div class="notif-header">
            <h3>Thông Báo</h3>
            @if (totalPending > 0)
            {
                <span class="notif-count">@totalPending yêu cầu mới</span>
            }
        </div>
        
        <div class="notif-list">
            @if (Model.Any())
            {
                @foreach (var res in Model)
                {
                    <a asp-controller="AdminReservations" asp-action="Index" class="notif-item">
                        <div class="notif-item-icon">📅</div>
                        <div class="notif-item-body">
                            <p class="notif-item-title"><strong>@res.FullName</strong> đã đặt bàn</p>
                            <p class="notif-item-subtitle">@res.GuestCount khách · @res.BookingDate.ToString("dd/MM") @@ @res.BookingTime</p>
                            <p class="notif-item-time">@res.CreatedAt.ToString("HH:mm dd/MM")</p>
                        </div>
                    </a>
                }
            }
            else
            {
                <div class="notif-empty">
                    <p>Không có thông báo mới nào.</p>
                </div>
            }
        </div>
        
        <div class="notif-footer">
            <a asp-controller="AdminReservations" asp-action="Index">Xem tất cả yêu cầu</a>
        </div>
    </div>
</div>

<style>
    .notification-wrapper { position: relative; }
    .notif-dot {
        position: absolute; top: -5px; right: -5px;
        background: #e74c3c; color: #fff; font-size: 0.65rem;
        font-weight: 700; width: 18px; height: 18px;
        border-radius: 50%; display: flex; align-items: center; justify-content: center;
        border: 2px solid var(--black);
    }

    .notif-dropdown {
        position: absolute; top: 50px; right: 0; width: 320px;
        background: var(--black-3); border: 1px solid rgba(201,168,76,.2);
        box-shadow: 0 10px 40px rgba(0,0,0,0.5); z-index: 100;
        display: none; flex-direction: column;
        animation: slideInDown 0.3s cubic-bezier(.22,1,.36,1) both;
    }
    .notif-dropdown.show { display: flex; }

    @@keyframes slideInDown {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .notif-header { padding: 16px 20px; border-bottom: 1px solid rgba(201,168,76,.12); display: flex; justify-content: space-between; align-items: center; }
    .notif-header h3 { font-size: 0.9rem; color: var(--gold); font-weight: 600; margin: 0; }
    .notif-count { font-size: 0.7rem; background: rgba(201,168,76,.1); color: var(--gold-light); padding: 2px 8px; border-radius: 10px; }

    .notif-list { max-height: 400px; overflow-y: auto; }
    .notif-list::-webkit-scrollbar { width: 4px; }
    .notif-list::-webkit-scrollbar-thumb { background: var(--gold); border-radius: 4px; }

    .notif-item {
        display: flex; gap: 12px; padding: 16px 20px; text-decoration: none;
        border-bottom: 1px solid rgba(201,168,76,.06); transition: background 0.2s;
    }
    .notif-item:hover { background: rgba(201,168,76,.05); }
    .notif-item-icon { width: 36px; height: 36px; background: var(--black-4); border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 1rem; }
    .notif-item-body { flex: 1; min-width: 0; }
    .notif-item-title { font-size: 0.82rem; color: var(--cream); margin: 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .notif-item-subtitle { font-size: 0.75rem; color: var(--text-soft); margin: 2px 0; }
    .notif-item-time { font-size: 0.68rem; color: var(--text-muted); margin: 0; }

    .notif-empty { padding: 32px 20px; text-align: center; color: var(--text-muted); font-size: 0.85rem; }
    
    .notif-footer { padding: 12px; text-align: center; border-top: 1px solid rgba(201,168,76,.12); background: var(--black-4); }
    .notif-footer a { font-size: 0.78rem; color: var(--gold-light); text-decoration: none; font-weight: 500; }
    .notif-footer a:hover { text-decoration: underline; }
</style>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const bell = document.getElementById('notificationBell');
        const dropdown = document.getElementById('notifDropdown');
        
        if (bell && dropdown) {
            bell.addEventListener('click', function(e) {
                e.stopPropagation();
                dropdown.classList.toggle('show');
            });

            document.addEventListener('click', function(e) {
                if (!dropdown.contains(e.target) && !bell.contains(e.target)) {
                    dropdown.classList.remove('show');
                }
            });
        }
    });
</script>
