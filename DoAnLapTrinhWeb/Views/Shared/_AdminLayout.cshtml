<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"] — Vermeil Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>

<!-- ══ SIDEBAR ══ -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <a href="#">VERMEIL<sup>®</sup></a>
    <p>Admin Dashboard</p>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section-label">Tổng Quan</div>
    <a href="#" class="nav-item">
      <span class="nav-icon">📊</span> Dashboard
    </a>
    <a href="#" class="nav-item">
      <span class="nav-icon">📅</span> Đặt Bàn
      <span class="nav-badge">12</span>
    </a>

    <div class="nav-section-label">Thực Đơn</div>
    <a href="#" class="nav-item active">
      <span class="nav-icon">🍽️</span> Quản Lý Món Ăn
    </a>
    <a href="#" class="nav-item">
      <span class="nav-icon">🗂️</span> Danh Mục
    </a>
    <a href="#" class="nav-item">
      <span class="nav-icon">🏷️</span> Giá & Khuyến Mãi
    </a>

    <div class="nav-section-label">Vận Hành</div>
    <a href="#" class="nav-item">
      <span class="nav-icon">🪑</span> Sơ Đồ Bàn
    </a>
    <a href="#" class="nav-item">
      <span class="nav-icon">📦</span> Đơn Hàng
      <span class="nav-badge">5</span>
    </a>
    <a href="#" class="nav-item">
      <span class="nav-icon">📈</span> Doanh Thu
    </a>

    <div class="nav-section-label">Hệ Thống</div>
    <a href="#" class="nav-item">
      <span class="nav-icon">👥</span> Nhân Viên
    </a>
    <a href="#" class="nav-item">
      <span class="nav-icon">⚙️</span> Cài Đặt
    </a>
  </nav>

  <div class="sidebar-footer">
    <div class="admin-info">
      <div class="admin-avatar">👑</div>
      <div class="admin-detail">
        <strong>Nguyễn Minh Tú</strong>
        <span>Super Admin</span>
      </div>
    </div>
    <button class="btn-logout">⬡ Đăng Xuất</button>
  </div>
</aside>

<main class="main">
<!-- TOPBAR -->
  <div class="topbar">
    <div class="topbar-left">
      <h1>Quản Lý Thực Đơn</h1>
      <p>Vermeil Fine Dining · Cập nhật lần cuối: hôm nay, 14:32</p>
    </div>
    <div class="topbar-right">
      <div class="topbar-search">
        <span>🔍</span>
        <input type="text" placeholder="Tìm kiếm món ăn..."/>
      </div>
      <div class="topbar-icon">
        🔔
        <span class="notif-dot"></span>
      </div>
      <div class="topbar-icon">👤</div>
    </div>
  @RenderBody()
</main>

<!-- ══ MODAL: THÊM MÓN ══ -->
<div class="modal-overlay" id="modalAdd">
  <div class="modal">
    <button class="modal-close" onclick="document.getElementById('modalAdd').classList.remove('show')">✕</button>
    <h3>Thêm Món Mới</h3>
    <p>Điền đầy đủ thông tin · Lưu để cập nhật thực đơn</p>

    <div class="form-group-m">
      <label>Tên Món</label>
      <input type="text" placeholder="Nhập tên món ăn..."/>
    </div>
    <div class="form-row-2">
      <div class="form-group-m">
        <label>Danh Mục</label>
        <select>
          <option>— Chọn danh mục —</option>
          <option>Khai Vị</option>
          <option>Món Chính</option>
          <option>Tráng Miệng</option>
          <option>Đồ Uống</option>
        </select>
      </div>
      <div class="form-group-m">
        <label>Giá (₫)</label>
        <input type="text" placeholder="0"/>
      </div>
    </div>
    <div class="form-group-m">
      <label>Mô Tả</label>
      <textarea placeholder="Mô tả nguyên liệu và cách chế biến..."></textarea>
    </div>
    <div class="form-row-2">
      <div class="form-group-m">
        <label>Badge / Nhãn</label>
        <select>
          <option>— Không có —</option>
          <option>Mới</option>
          <option>Signature</option>
          <option>Phổ Biến</option>
          <option>Chef's Pick</option>
        </select>
      </div>
      <div class="form-group-m">
        <label>Trạng Thái</label>
        <select>
          <option>Hiển thị</option>
          <option>Ẩn</option>
        </select>
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn-modal-cancel" onclick="document.getElementById('modalAdd').classList.remove('show')">Huỷ</button>
      <button class="btn-modal-save">＋ Lưu Món Mới</button>
    </div>
  </div>
</div>

<!-- ══ MODAL: SỬA MÓN ══ -->
<div class="modal-overlay" id="modalEdit">
  <div class="modal">
    <button class="modal-close" onclick="document.getElementById('modalEdit').classList.remove('show')">✕</button>
    <h3>Chỉnh Sửa Món Ăn</h3>
    <p>Cập nhật thông tin · Lưu để áp dụng thay đổi</p>

    <div class="form-group-m">
      <label>Tên Món</label>
      <input type="text" value="Bò Wagyu A5 Áp Chảo"/>
    </div>
    <div class="form-row-2">
      <div class="form-group-m">
        <label>Danh Mục</label>
        <select>
          <option>Khai Vị</option>
          <option selected>Món Chính</option>
          <option>Tráng Miệng</option>
          <option>Đồ Uống</option>
        </select>
      </div>
      <div class="form-group-m">
        <label>Giá (₫)</label>
        <input type="text" value="480000"/>
      </div>
    </div>
    <div class="form-group-m">
      <label>Mô Tả</label>
      <textarea>Thăn bò Wagyu A5 nhập khẩu Nhật Bản nướng medium-rare, kèm nấm truffle đen và rau củ nướng thảo mộc.</textarea>
    </div>
    <div class="form-row-2">
      <div class="form-group-m">
        <label>Badge / Nhãn</label>
        <select>
          <option selected>Signature</option>
          <option>Mới</option>
          <option>Phổ Biến</option>
          <option>Chef's Pick</option>
        </select>
      </div>
      <div class="form-group-m">
        <label>Trạng Thái</label>
        <select>
          <option selected>Hiển thị</option>
          <option>Ẩn</option>
        </select>
      </div>
    </div>
    <div class="modal-actions">
      <button class="btn-modal-cancel" onclick="document.getElementById('modalEdit').classList.remove('show')">Huỷ</button>
      <button class="btn-modal-save">✓ Lưu Thay Đổi</button>
    </div>
  </div>
</div>

<!-- ══ MODAL: XOÁ ══ -->
<div class="modal-overlay" id="modalDelete">
  <div class="modal modal-delete">
    <button class="modal-close" onclick="document.getElementById('modalDelete').classList.remove('show')">✕</button>
    <div class="del-icon">🗑️</div>
    <h3>Xác Nhận Xoá Món</h3>
    <p>Bạn có chắc muốn xoá <strong style="color:var(--gold)">"Bò Wagyu A5 Áp Chảo"</strong> khỏi thực đơn? Hành động này không thể hoàn tác.</p>
    <div class="modal-actions">
      <button class="btn-modal-cancel" onclick="document.getElementById('modalDelete').classList.remove('show')">Huỷ Bỏ</button>
      <button class="btn-confirm-del">✕ Xác Nhận Xoá</button>
    </div>
  </div>
</div>

<script>
  // Close modal when clicking overlay background
  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', function(e) {
      if (e.target === this) this.classList.remove('show');
    });
  });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>