<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"] — Vermeil Admin</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>

<!-- ══ SIDEBAR ══ -->
<aside class="sidebar">
  <div class="sidebar-logo">
    <a href="#">VERMEIL<sup>®</sup></a>
    <p>Admin Dashboard</p>
  </div>

  <nav class="sidebar-nav">
    <div class="nav-section-label">Tổng Quan</div>
    <a asp-area="" asp-controller="AdminReservations" asp-action="Index" class="nav-item">
      <span class="nav-icon">📅</span> Đặt Bàn
    </a>

    <div class="nav-section-label">Thực Đơn</div>
    <a asp-area="" asp-controller="AdminMenu" asp-action="Index" class="nav-item">
      <span class="nav-icon">🍽️</span> Quản Lý Món Ăn
    </a>
    <a href="#" class="nav-item">
      <span class="nav-icon">🏷️</span> Giá & Khuyến Mãi
    </a>

    <div class="nav-section-label">Vận Hành</div>
    <a href="#" class="nav-item">
      <span class="nav-icon">🪑</span> Sơ Đồ Bàn
    </a>
    <a href="#" class="nav-item">
      <span class="nav-icon">📦</span> Đơn Đặt Bàn
      <span class="nav-badge">5</span>
    </a>
    <a href="#" class="nav-item">
      <span class="nav-icon">📈</span> Doanh Thu
    </a>

    <div class="nav-section-label">Hệ Thống</div>
    <a href="#" class="nav-item">
      <span class="nav-icon">⚙️</span> Cài Đặt
    </a>
  </nav>

  @using Microsoft.AspNetCore.Identity
  @using DoAnLapTrinhWeb.Models
  @inject SignInManager<ApplicationUser> SignInManager
  @inject UserManager<ApplicationUser> UserManager

  <div class="sidebar-footer">
    <div class="admin-info">
      <div class="admin-avatar">👑</div>
      <div class="admin-detail">
        @{
            var currentUser = await UserManager.GetUserAsync(User);
            var displayName = currentUser?.FullName ?? "Admin";
        }
        <strong>@displayName</strong>
        <span>Super Admin</span>
      </div>
    </div>
    <form asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
        <button type="submit" class="btn-logout" style="width:100%; text-align:left; border:none; cursor:pointer;">⬡ Đăng Xuất</button>
    </form>
  </div>
</aside>

<main class="main">
<!-- TOPBAR -->
  <div class="topbar">
    <div class="topbar-left">
      <h1>Quản Lý Thực Đơn</h1>
      <p>Vermeil Fine Dining · Cập nhật lần cuối: hôm nay, 14:32</p>
    </div>
    <div class="topbar-right">
      <div class="topbar-search">
        <span>🔍</span>
        <input type="text" placeholder="Tìm kiếm món ăn..."/>
      </div>
      <div class="topbar-icon">
        🔔
        <span class="notif-dot"></span>
      </div>
      <div class="topbar-icon">👤</div>
    </div>
  </div>
  @RenderBody()
</main>

<script>
  // Close modal when clicking overlay background
  document.querySelectorAll('.modal-overlay').forEach(overlay => {
    overlay.addEventListener('click', function(e) {
      if (e.target === this) this.classList.remove('show');
    });
  });
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>