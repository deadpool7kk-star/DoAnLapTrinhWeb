@model IEnumerable<DoAnLapTrinhWeb.Models.Reservation>
@{
    ViewData["Title"] = "Quản Lý Đặt Bàn";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["ShowBack"] = true;
    ViewData["BackUrl"] = Url.Action("Index", "Home");
}

<style>
    /* Tùy chỉnh SweetAlert2 Select để phù hợp với theme Vermeil */
    .swal2-popup {
        border: 1px solid rgba(201, 168, 76, 0.3) !important;
        border-top: 2px solid #c9a84c !important;
        box-shadow: 0 10px 40px rgba(0,0,0,0.8) !important;
        border-radius: 0 !important;
    }

    .swal2-select {
        background-color: #2a1f1a !important;
        color: #f5ede0 !important;
        border: 1px solid rgba(201, 168, 76, 0.3) !important;
        border-radius: 0 !important;
        padding: 12px !important;
        font-family: 'Jost', sans-serif !important;
        font-size: 0.9rem !important;
        outline: none !important;
        min-width: 80% !important;
        margin: 20px auto !important;
    }

    .swal2-select:focus {
        border-color: #c9a84c !important;
        box-shadow: 0 0 10px rgba(201, 168, 76, 0.2) !important;
    }

    /* Fix màu chữ trong option */
    .swal2-select option {
        background-color: #1c1512 !important;
        color: #f5ede0 !important;
        padding: 10px !important;
    }

    .swal2-title {
        font-family: 'Playfair Display', serif !important;
        font-weight: 500 !important;
        color: #f5ede0 !important;
        letter-spacing: 0.05em !important;
    }

    .swal2-actions {
        margin-top: 20px !important;
    }

    .swal2-confirm {
        border-radius: 0 !important;
        font-family: 'Jost', sans-serif !important;
        font-weight: 500 !important;
        letter-spacing: 0.1em !important;
        text-transform: uppercase !important;
        padding: 12px 30px !important;
    }

    .swal2-cancel {
        border-radius: 0 !important;
        font-family: 'Jost', sans-serif !important;
        font-weight: 500 !important;
        letter-spacing: 0.1em !important;
        text-transform: uppercase !important;
        padding: 12px 30px !important;
    }

    /* Tùy chỉnh Table Picker Grid */
    .table-picker-grid {
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        gap: 12px;
        max-height: 280px;
        overflow-y: auto;
        padding: 10px;
        margin-top: 15px;
    }

    .table-picker-item {
        background: #2a1f1a;
        border: 1px solid rgba(201, 168, 76, 0.2);
        padding: 15px;
        text-align: left;
        cursor: pointer;
        transition: all 0.2s ease;
        position: relative;
    }

    .table-picker-item:hover {
        border-color: #c9a84c;
        background: rgba(201, 168, 76, 0.1);
        transform: translateY(-2px);
    }

    .table-picker-item.selected {
        border-color: #c9a84c;
        background: rgba(201, 168, 76, 0.2);
        box-shadow: 0 0 15px rgba(201, 168, 76, 0.3);
    }

    .table-picker-item.selected::after {
        content: '✓';
        position: absolute;
        top: 8px;
        right: 12px;
        color: #c9a84c;
        font-weight: bold;
    }

    .picker-name {
        display: block;
        font-weight: 600;
        color: #e2c47a;
        font-size: 0.95rem;
        margin-bottom: 4px;
    }

    .picker-info {
        display: block;
        font-size: 0.75rem;
        color: rgba(245, 237, 224, 0.5);
    }

    .table-picker-grid::-webkit-scrollbar { width: 4px; }
    .table-picker-grid::-webkit-scrollbar-track { background: #1c1512; }
    .table-picker-grid::-webkit-scrollbar-thumb { background: #c9a84c; border-radius: 4px; }

    /* Chi tiết Grid */
    .details-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 24px;
        margin-top: 10px;
    }
    .detail-item label {
        display: block;
        font-size: 0.62rem;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--text-muted);
        margin-bottom: 8px;
    }
    .detail-val {
        font-size: 0.92rem;
        color: var(--cream);
        font-weight: 500;
    }

    .table-picker-item.disabled {
        opacity: 0.4;
        background: #1a1512 !important;
        border-color: rgba(255, 255, 255, 0.05) !important;
        cursor: not-allowed;
        filter: grayscale(1);
    }
    
    .status-tag {
        font-size: 0.65rem;
        padding: 2px 6px;
        background: rgba(231, 76, 60, 0.2);
        color: #e74c3c;
        float: right;
        border-radius: 4px;
    }

    /* ── UNIFIED ACTION BUTTONS ── */
    .action-group {
        display: flex;
        gap: 8px;
        justify-content: flex-end;
        align-items: center;
    }

    .btn-action {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 6px;
        height: 32px;
        padding: 0 12px;
        font-family: 'Jost', sans-serif;
        font-size: 0.72rem;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        cursor: pointer;
        transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
        border: 1px solid transparent;
        background: transparent;
        color: var(--text-muted);
        text-decoration: none;
        white-space: nowrap;
    }

    .btn-action:hover {
        transform: translateY(-1px);
        box-shadow: 0 3px 10px rgba(0,0,0,0.2);
    }

    .btn-action:active {
        transform: translateY(0);
    }

    /* Success Theme (Duyệt) */
    .btn-action-success {
        border-color: rgba(126, 205, 160, 0.3);
        color: #7ecda0;
    }
    .btn-action-success:hover {
        background: #7ecda0;
        color: var(--black);
        border-color: #7ecda0;
    }

    /* Primary Theme (Xếp Bàn, Lập Hóa Đơn) */
    .btn-action-primary {
        border-color: rgba(201, 168, 76, 0.3);
        color: var(--gold);
    }
    .btn-action-primary:hover {
        background: var(--gold);
        color: var(--black);
        border-color: var(--gold);
    }

    /* Danger Theme (Hủy, Xóa) */
    .btn-action-danger {
        border-color: rgba(192, 57, 43, 0.3);
        color: #e08080;
    }
    .btn-action-danger:hover {
        background: #9e2020;
        color: #fff;
        border-color: #9e2020;
    }

    /* Info Theme (Chi tiết) */
    .btn-action-info {
        border-color: rgba(245, 237, 224, 0.15);
        color: var(--text-soft);
    }
    .btn-action-info:hover {
        background: rgba(245, 237, 224, 0.1);
        border-color: rgba(245, 237, 224, 0.3);
        color: var(--cream);
    }
</style>

<div class="page-body">
    <!-- STATS -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-card-top">
                <div class="stat-card-icon">📅</div>
                <span class="stat-trend">—</span>
            </div>
            <div class="stat-card-num">@Model.Count()</div>
            <div class="stat-card-label">Tổng Lượt Đặt</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-top">
                <div class="stat-card-icon">⏳</div>
                <span class="stat-trend">@Model.Count(r => r.Status == "Pending") mới</span>
            </div>
            <div class="stat-card-num">@Model.Count(r => r.Status == "Pending")</div>
            <div class="stat-card-label">Chờ Xác Nhận</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-top">
                <div class="stat-card-icon">✅</div>
                <span class="stat-trend">—</span>
            </div>
            <div class="stat-card-num">@Model.Count(r => r.Status == "Confirmed")</div>
            <div class="stat-card-label">Đã Xác Nhận</div>
        </div>
        <div class="stat-card">
            <div class="stat-card-top">
                <div class="stat-card-icon">✕</div>
                <span class="stat-trend">—</span>
            </div>
            <div class="stat-card-num">@Model.Count(r => r.Status == "Cancelled")</div>
            <div class="stat-card-label">Đã Hủy</div>
        </div>
    </div>

    <!-- TABLE SECTION -->
    <div class="section-header">
        <div class="section-header-left">
            <h2>Danh Sách Đặt Bàn</h2>
            <p>Xác nhận và quản lý các yêu cầu đặt chỗ từ khách hàng</p>
        </div>
    </div>

    <!-- TABLE -->
    <div class="table-wrap">
        <table>
            <thead>
                <tr>
                    <th>Khách Hàng</th>
                    <th>Liên Hệ</th>
                    <th>Thời Gian</th>
                    <th>Số Khách</th>
                    <th>Trạng Thái</th>
                    <th>Ghi Chú</th>
                    <th>Thao Tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            <div class="td-dish">
                                <div class="td-icon">👤</div>
                                <div>
                                    <div class="td-dish-name">@item.FullName</div>
                                    <div class="td-dish-cat">Đặt lúc: @item.CreatedAt.ToString("HH:mm dd/MM")</div>
                                </div>
                            </div>
                        </td>
                        <td>
                            <div style="font-size: 0.85rem; color: var(--gold);">@item.Phone</div>
                        </td>
                        <td>
                            <div style="font-size: 0.85rem;">@item.BookingDate.ToString("dd/MM/yyyy")</div>
                            <div style="font-size: 0.75rem; color: var(--text-muted);">@item.BookingTime</div>
                        </td>
                        <td>
                            <span style="font-weight: 500; color: var(--cream);">@item.GuestCount</span>
                        </td>
                        <td>
                            @if (item.Status == "Pending")
                            {
                                <span class="status-badge" style="color: #e2c47a; border-color: rgba(226,196,122,0.3);">Đang Chờ</span>
                            }
                            else if (item.Status == "Confirmed")
                            {
                                <span class="status-badge active">Đã Xác Nhận</span>
                            }
                            else if (item.Status == "Seated")
                            {
                                <span class="status-badge" style="color: #60a5fa; border-color: rgba(96,165,250,0.3);">Đã Ngồi Bàn @(item.Table?.Name)</span>
                            }
                            else if (item.Status == "Completed")
                            {
                                <span class="status-badge" style="color: #9ca3af; border-color: rgba(156,163,175,0.3);">Hoàn Tất</span>
                            }
                            else
                            {
                                <span class="status-badge hidden">Đã Hủy</span>
                            }
                        </td>
                        <td>
                            <div style="font-size: 0.75rem; max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="@item.Note">
                                @(string.IsNullOrEmpty(item.Note) ? "—" : item.Note)
                            </div>
                        </td>
                        <td>
                            <div class="action-group">
                                @if (item.Status == "Pending")
                                {
                                    <form asp-action="Confirm" asp-route-id="@item.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn-action btn-action-success">✓ Duyệt</button>
                                    </form>
                                    <form asp-action="Cancel" asp-route-id="@item.Id" method="post" style="display:inline;">
                                        <button type="submit" class="btn-action btn-action-danger">✕ Hủy</button>
                                    </form>
                                }
                                else if (item.Status == "Confirmed")
                                {
                                    <button onclick="assignTable(@item.Id)" class="btn-action btn-action-primary">🍽️ Xếp Bàn</button>
                                }
                                else if (item.Status == "Seated")
                                {
                                    <a asp-controller="AdminInvoices" asp-action="Create" asp-route-tableId="@item.TableId" asp-route-customerName="@item.FullName" asp-route-reservationId="@item.Id" class="btn-action btn-action-primary">
                                        💰 Lập Hóa Đơn
                                    </a>
                                }
                                
                                <form asp-action="Delete" asp-route-id="@item.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn-action btn-action-danger" onclick="return confirm('Xóa vĩnh viễn yêu cầu này?')">🗑 Xóa</button>
                                </form>

                                <button onclick="viewDetails(@item.Id)" class="btn-action btn-action-info" title="Xem chi tiết">🔍 Chi tiết</button>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" style="text-align: center; padding: 40px; color: var(--text-muted);">
                            Chưa có yêu cầu đặt bàn nào.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- MODAL CHI TIẾT -->
<div id="detailsModal" class="modal-overlay">
    <div class="modal" style="max-width: 600px;">
        <button class="modal-close" onclick="closeDetailsModal()">&times;</button>
        <h3>Chi Tiết Đặt Bàn</h3>
        <p style="margin-bottom: 25px;">Toàn bộ thông tin khách hàng và yêu cầu</p>

        <div class="details-grid">
            <div class="detail-item">
                <label>Khách Hàng</label>
                <div id="detFullName" class="detail-val"></div>
            </div>
            <div class="detail-item">
                <label>Số Điện Thoại</label>
                <div id="detPhone" class="detail-val" style="color: var(--gold);"></div>
            </div>
            <div class="detail-item">
                <label>Ngày Đặt</label>
                <div id="detDate" class="detail-val"></div>
            </div>
            <div class="detail-item">
                <label>Giờ Đặt</label>
                <div id="detTime" class="detail-val"></div>
            </div>
            <div class="detail-item">
                <label>Số Khách</label>
                <div id="detGuests" class="detail-val"></div>
            </div>
            <div class="detail-item">
                <label>Bàn Chỉ Định</label>
                <div id="detTable" class="detail-val" style="color: var(--gold-light);"></div>
            </div>
            <div class="detail-item" style="grid-column: span 2;">
                <label>Ghi Chú</label>
                <div id="detNote" class="detail-val" style="white-space: pre-wrap; font-style: italic; color: var(--text-soft);"></div>
            </div>
            <div class="detail-item">
                <label>Trạng Thái</label>
                <div id="detStatus" class="detail-val"></div>
            </div>
            <div class="detail-item">
                <label>Thời Gian Gửi Yêu Cầu</label>
                <div id="detCreatedAt" class="detail-val" style="font-size: 0.8rem; color: var(--text-muted);"></div>
            </div>
        </div>

        <div class="modal-actions" style="margin-top: 35px;">
            <button class="btn-modal-cancel" style="width: 100%;" onclick="closeDetailsModal()">Đóng Cửa Sổ</button>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        const allTables = @Html.Raw(Json.Serialize(ViewBag.AllTables));

        function assignTable(reservationId) {
            if (!allTables || allTables.length === 0) {
                Swal.fire({
                    icon: 'warning',
                    title: 'Hết bàn trống',
                    text: 'Hiện tại không còn bàn nào ở trạng thái Sẵn sàng.',
                    background: '#1c1512',
                    color: '#f5ede0',
                    confirmButtonColor: '#c9a84c'
                });
                return;
            }

            let gridHtml = `
                <div style="margin-bottom: 10px; font-size: 0.85rem; color: rgba(245,237,224,0.6);">
                    Vui lòng chọn một bàn đang sẵn sàng từ danh sách bên dưới
                </div>
                <div class="table-picker-grid">
            `;
            allTables.forEach(t => {
                const isBusy = t.status !== 'Available';
                const statusText = t.status === 'Occupied' ? 'Hết chỗ' : (t.status === 'Reserved' ? 'Đã đặt' : '');
                
                gridHtml += `
                    <div class="table-picker-item ${isBusy ? 'disabled' : ''}" ${isBusy ? '' : `onclick="selectPickerTable(this, ${t.id})"`}>
                        ${isBusy ? `<span class="status-tag">${statusText}</span>` : ''}
                        <span class="picker-name">${t.name}</span>
                        <span class="picker-info">Lầu ${t.floor} • ${t.capacity} người</span>
                    </div>
                `;
            });
            gridHtml += '</div><input type="hidden" id="selectedTableId" value="">';

            Swal.fire({
                title: 'Lựa chọn bàn trống',
                html: gridHtml,
                background: '#1c1512',
                color: '#f5ede0',
                showCancelButton: true,
                confirmButtonColor: '#c9a84c',
                cancelButtonColor: '#4a322d',
                confirmButtonText: 'Xác nhận xếp bàn',
                cancelButtonText: 'Đóng',
                position: 'center',
                preConfirm: () => {
                    const tableId = document.getElementById('selectedTableId').value;
                    if (!tableId) {
                        Swal.showValidationMessage('Vui lòng chọn một bàn để tiếp tục');
                    }
                    return tableId;
                }
            }).then((result) => {
                if (result.isConfirmed) {
                    const tableId = result.value;
                    
                    // Show loading
                    Swal.fire({
                        title: 'Đang xử lý...',
                        allowOutsideClick: false,
                        didOpen: () => {
                            Swal.showLoading();
                        },
                        background: '#1c1512',
                        color: '#f5ede0'
                    });

                    $.ajax({
                        url: '/AdminReservations/AssignTable',
                        type: 'POST',
                        data: { id: reservationId, tableId: tableId },
                        success: function(data) {
                            if (data.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Thành công',
                                    text: 'Đã xếp khách vào bàn và cập nhật sơ đồ.',
                                    background: '#1c1512',
                                    color: '#f5ede0',
                                    confirmButtonColor: '#c9a84c'
                                }).then(() => {
                                    window.location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Lỗi',
                                    text: data.message || 'Không thể xếp bàn.',
                                    background: '#1c1512',
                                    color: '#f5ede0'
                                });
                            }
                        },
                        error: function() {
                            Swal.fire({
                                icon: 'error',
                                title: 'Lỗi kết nối',
                                text: 'Không thể gửi yêu cầu tới máy chủ. Vui lòng thử lại.',
                                background: '#1c1512',
                                color: '#f5ede0'
                            });
                        }
                    });
                }
            });
        }

        function selectPickerTable(element, id) {
            document.querySelectorAll('.table-picker-item').forEach(el => el.classList.remove('selected'));
            element.classList.add('selected');
            document.getElementById('selectedTableId').value = id;
        }

        function viewDetails(id) {
            $.get('/AdminReservations/GetDetails/' + id, function(data) {
                $('#detFullName').text(data.fullName);
                $('#detPhone').text(data.phone);
                $('#detDate').text(data.date);
                $('#detTime').text(data.time);
                $('#detGuests').text(data.guests);
                $('#detTable').text(data.tableName);
                $('#detNote').text(data.note);
                
                let statusText = data.status;
                if(data.status === 'Pending') statusText = 'Đang chờ';
                if(data.status === 'Confirmed') statusText = 'Đã xác nhận';
                if(data.status === 'Seated') statusText = 'Đã ngồi bàn';
                if(data.status === 'Completed') statusText = 'Hoàn tất';
                if(data.status === 'Cancelled') statusText = 'Đã hủy';
                
                $('#detStatus').text(statusText);
                $('#detCreatedAt').text(data.createdAt);
                
                $('#detailsModal').addClass('show');
            });
        }

        function closeDetailsModal() {
            $('#detailsModal').removeClass('show');
        }
    </script>
}
