@{
    ViewData["Title"] = "Quản Lý Thực Đơn";
    Layout = "_AdminLayout";
}
<!-- PAGE BODY -->
<div class="page-body">

    <!-- STATS -->
    <div class="stats-row">
      <div class="stat-card">
        <div class="stat-card-top">
          <div class="stat-card-icon">🍽️</div>
          <span class="stat-trend">↑ 3 mới</span>
        </div>
        <div class="stat-card-num">42</div>
        <div class="stat-card-label">Tổng Món Ăn</div>
      </div>
      <div class="stat-card">
        <div class="stat-card-top">
          <div class="stat-card-icon">✅</div>
          <span class="stat-trend">↑ 2%</span>
        </div>
        <div class="stat-card-num">38</div>
        <div class="stat-card-label">Đang Hiển Thị</div>
      </div>
      <div class="stat-card">
        <div class="stat-card-top">
          <div class="stat-card-icon">🗂️</div>
          <span class="stat-trend">—</span>
        </div>
        <div class="stat-card-num">5</div>
        <div class="stat-card-label">Danh Mục</div>
      </div>
      <div class="stat-card">
        <div class="stat-card-top">
          <div class="stat-card-icon">⭐</div>
          <span class="stat-trend down">↓ 1</span>
        </div>
        <div class="stat-card-num">4</div>
        <div class="stat-card-label">Ẩn / Hết Món</div>
      </div>
    </div>

    <!-- TABLE SECTION -->
    <div class="section-header">
      <div class="section-header-left">
        <h2>Danh Sách Món Ăn</h2>
        <p>Quản lý toàn bộ thực đơn nhà hàng</p>
      </div>
      <div class="section-header-right">
        <button class="btn-filter" onclick="document.getElementById('modalAdd').classList.add('show')">
          ⚙ Lọc
        </button>
        <button class="btn-add" onclick="document.getElementById('modalAdd').classList.add('show')">
          ＋ Thêm Món Mới
        </button>
      </div>
    </div>

    <!-- TABS -->
    <div class="tab-row">
      <button class="tab active">Tất Cả (42)</button>
      <button class="tab">Khai Vị (8)</button>
      <button class="tab">Món Chính (18)</button>
      <button class="tab">Tráng Miệng (10)</button>
      <button class="tab">Đồ Uống (6)</button>
    </div>

    <!-- TABLE -->
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>#</th>
            <th>Tên Món</th>
            <th>Danh Mục</th>
            <th>Giá</th>
            <th>Trạng Thái</th>
            <th>Cập Nhật</th>
            <th>Thao Tác</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td style="color:var(--text-muted);font-size:.78rem">01</td>
            <td>
              <div class="td-dish">
                <div class="td-icon">🥩</div>
                <div>
                  <div class="td-dish-name">Bò Wagyu A5 Áp Chảo</div>
                  <div class="td-dish-cat">Món Chính · Signature</div>
                </div>
              </div>
            </td>
            <td>Món Chính</td>
            <td><span class="price-cell">480.000₫</span></td>
            <td><span class="status-badge active">Hiển thị</span></td>
            <td style="font-size:.76rem;color:var(--text-muted)">12/03/2025</td>
            <td>
              <div class="action-group">
                <button class="btn-view">👁</button>
                <button class="btn-edit" onclick="document.getElementById('modalEdit').classList.add('show')">✏ Sửa</button>
                <button class="btn-delete" onclick="document.getElementById('modalDelete').classList.add('show')">✕ Xoá</button>
              </div>
            </td>
          </tr>
          <tr>
            <td style="color:var(--text-muted);font-size:.78rem">02</td>
            <td>
              <div class="td-dish">
                <div class="td-icon">🐟</div>
                <div>
                  <div class="td-dish-name">Cá Hồi Sốt Chanh Bơ</div>
                  <div class="td-dish-cat">Món Chính · Mới</div>
                </div>
              </div>
            </td>
            <td>Món Chính</td>
            <td><span class="price-cell">295.000₫</span></td>
            <td><span class="status-badge active">Hiển thị</span></td>
            <td style="font-size:.76rem;color:var(--text-muted)">15/03/2025</td>
            <td>
              <div class="action-group">
                <button class="btn-view">👁</button>
                <button class="btn-edit" onclick="document.getElementById('modalEdit').classList.add('show')">✏ Sửa</button>
                <button class="btn-delete" onclick="document.getElementById('modalDelete').classList.add('show')">✕ Xoá</button>
              </div>
            </td>
          </tr>
          <tr>
            <td style="color:var(--text-muted);font-size:.78rem">03</td>
            <td>
              <div class="td-dish">
                <div class="td-icon">🍝</div>
                <div>
                  <div class="td-dish-name">Pasta Nấm Truffle Đen</div>
                  <div class="td-dish-cat">Món Chính · Chef's Pick</div>
                </div>
              </div>
            </td>
            <td>Món Chính</td>
            <td><span class="price-cell">225.000₫</span></td>
            <td><span class="status-badge active">Hiển thị</span></td>
            <td style="font-size:.76rem;color:var(--text-muted)">10/03/2025</td>
            <td>
              <div class="action-group">
                <button class="btn-view">👁</button>
                <button class="btn-edit" onclick="document.getElementById('modalEdit').classList.add('show')">✏ Sửa</button>
                <button class="btn-delete" onclick="document.getElementById('modalDelete').classList.add('show')">✕ Xoá</button>
              </div>
            </td>
          </tr>
          <tr>
            <td style="color:var(--text-muted);font-size:.78rem">04</td>
            <td>
              <div class="td-dish">
                <div class="td-icon">🥗</div>
                <div>
                  <div class="td-dish-name">Salad Rau Mầm Hữu Cơ</div>
                  <div class="td-dish-cat">Khai Vị · Healthy</div>
                </div>
              </div>
            </td>
            <td>Khai Vị</td>
            <td><span class="price-cell">85.000₫</span></td>
            <td><span class="status-badge hidden">Đã ẩn</span></td>
            <td style="font-size:.76rem;color:var(--text-muted)">08/03/2025</td>
            <td>
              <div class="action-group">
                <button class="btn-view">👁</button>
                <button class="btn-edit" onclick="document.getElementById('modalEdit').classList.add('show')">✏ Sửa</button>
                <button class="btn-delete" onclick="document.getElementById('modalDelete').classList.add('show')">✕ Xoá</button>
              </div>
            </td>
          </tr>
          <tr>
            <td style="color:var(--text-muted);font-size:.78rem">05</td>
            <td>
              <div class="td-dish">
                <div class="td-icon">🍮</div>
                <div>
                  <div class="td-dish-name">Panna Cotta Vanilla Bourbon</div>
                  <div class="td-dish-cat">Tráng Miệng · Mới</div>
                </div>
              </div>
            </td>
            <td>Tráng Miệng</td>
            <td><span class="price-cell">95.000₫</span></td>
            <td><span class="status-badge active">Hiển thị</span></td>
            <td style="font-size:.76rem;color:var(--text-muted)">18/03/2025</td>
            <td>
              <div class="action-group">
                <button class="btn-view">👁</button>
                <button class="btn-edit" onclick="document.getElementById('modalEdit').classList.add('show')">✏ Sửa</button>
                <button class="btn-delete" onclick="document.getElementById('modalDelete').classList.add('show')">✕ Xoá</button>
              </div>
            </td>
          </tr>
        </tbody>
      </table>

      <!-- PAGINATION -->
      <div class="pagination">
        <p>Hiển thị 1–5 / 42 món</p>
        <div class="page-btns">
          <button class="page-btn">‹</button>
          <button class="page-btn active">1</button>
          <button class="page-btn">2</button>
          <button class="page-btn">3</button>
          <button class="page-btn">…</button>
          <button class="page-btn">9</button>
          <button class="page-btn">›</button>
        </div>
      </div>
    </div>

  </div>
<!-- /page-body -->