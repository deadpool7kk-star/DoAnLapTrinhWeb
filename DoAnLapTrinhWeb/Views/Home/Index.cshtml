@model IEnumerable<DoAnLapTrinhWeb.Models.Dish>
@{
    ViewData["Title"] = "Trang Chủ";
    var categories = ViewBag.Categories as IEnumerable<DoAnLapTrinhWeb.Models.Category> ?? new List<DoAnLapTrinhWeb.Models.Category>();
}
<section id="hero">
  <div class="hero-bg"></div>
  <div class="hero-grid"></div>
  <div class="hero-corner tl"></div><div class="hero-corner tr"></div>
  <div class="hero-corner bl"></div><div class="hero-corner br"></div>
  <div class="hero-content">
    <div class="hero-eyebrow"><span>Fine Dining · Sài Gòn · Est. 2012</span></div>
    <h1 class="hero-title">
      Nghệ Thuật
      <em>Ẩm Thực</em>
      <span class="outline">Đỉnh Cao</span>
    </h1>
    <p class="hero-sub">Trải nghiệm ẩm thực hoàng gia với nguyên liệu thượng hạng, không gian sang trọng và dịch vụ đẳng cấp quốc tế — nơi mỗi bữa ăn trở thành ký ức không thể quên.</p>
    <div class="hero-btns">
      <button class="btn-gold" onclick="document.getElementById('menu').scrollIntoView({behavior: 'smooth'})">Khám Phá Thực Đơn</button>
      <button class="btn-ghost" onclick="document.getElementById('reservation').scrollIntoView({behavior: 'smooth'})">Đặt Bàn Ngay</button>
    </div>
  </div>
  <div class="hero-visual">
    <div class="visual-inner">
      <img src="https://i.pinimg.com/736x/16/57/76/1657768b64383d87f0dccde854e6eecb.jpg" alt="Vermeil Fine Dining Excellence" />
      <div class="visual-deco-frame"></div>
    </div>
  </div>
  <div class="hero-scroll">Cuộn Xuống</div>
</section>

<!-- STATS -->
<div class="stats-strip">
  <div class="stat-item"><div class="stat-num">12+</div><div class="stat-label">Năm Kinh Nghiệm</div></div>
  <div class="stat-item"><div class="stat-num">4.9★</div><div class="stat-label">Đánh Giá Trung Bình</div></div>
  <div class="stat-item"><div class="stat-num">50k+</div><div class="stat-label">Lượt Khách</div></div>
  <div class="stat-item"><div class="stat-num">3</div><div class="stat-label">Giải Thưởng Quốc Tế</div></div>
</div>

<!-- MENU -->
<section id="menu">
  <div class="menu-header">
    <div class="section-eyebrow"><span>Thực Đơn</span></div>
    <h2 class="section-title">Tinh Hoa <em>Ẩm Thực</em></h2>
    <p>Mỗi món ăn là một tác phẩm được chắt lọc từ nguyên liệu tươi sạch nhất, chế biến bởi đội ngũ bếp trưởng đẳng cấp quốc tế.</p>
  </div>
  <div class="menu-tabs" id="menuTabs">
    <button class="tab-btn active" data-filter="all">Tất Cả</button>
    @foreach(var cat in categories)
    {
        <button class="tab-btn" data-filter="@cat.Name">@cat.Name</button>
    }
  </div>
  <div class="menu-grid" id="menuGrid">
    @foreach(var item in Model)
    {
        <div class="menu-card" data-category="@(item.Category?.Name)">
          <div class="menu-card-top">
            <div class="menu-icon">
                @if(!string.IsNullOrEmpty(item.ImageUrl))
                {
                    <img src="@item.ImageUrl" alt="@item.Name" style="width:100%; height:100%; object-fit:cover; border-radius:10px; transition: transform 0.6s cubic-bezier(0.19, 1, 0.22, 1);" />
                }
                else
                {
                    @(item.Icon ?? "🍽️")
                }
            </div>
            @if(!string.IsNullOrEmpty(item.Badge))
            {
                <span class="menu-badge gold">@item.Badge</span>
            }
          </div>
          <h4>@item.Name</h4>
          <p>@item.Description</p>
          <div class="menu-card-footer">
            <div class="price-wrap">
                @if(item.DiscountPercentage > 0)
                {
                    <span class="price-old">@item.Price.ToString("N0")₫</span>
                    <span class="price">@item.DiscountedPrice.ToString("N0")₫</span>
                }
                else
                {
                    <span class="price">@item.Price.ToString("N0")₫</span>
                }
            </div>
            <button class="add-btn">+</button>
          </div>
        </div>
    }
  </div>
</section>

<!-- ABOUT -->
<section id="about">
  <div class="about-grid">
    <div class="about-visual">
      <div class="about-frame-outer"></div>
      <div class="about-frame-inner">
        <img src="https://i.pinimg.com/736x/e1/2c/b5/e12cb5bf6722cc47bfcf54562f777160.jpg" alt="Vermeil Atmosphere" />
      </div>
      <div class="about-corner-deco"></div>
      <div class="about-corner-deco br"></div>
      <div class="about-badge-float">
        <div class="num">12+</div>
        <div class="lbl">Năm Thành Lập</div>
      </div>
    </div>
    <div class="about-text">
      <div class="section-eyebrow"><span>Về Chúng Tôi</span></div>
      <h2 class="section-title">Nơi Sang Trọng <em>Gặp Gỡ</em> Đam Mê</h2>
      <div class="about-divider"></div>
      <p>Vermeil được thành lập năm 2012 với triết lý đơn giản nhưng đầy tham vọng — tạo ra không gian ẩm thực đỉnh cao nơi mỗi bữa ăn là một hành trình trải nghiệm đa giác quan.</p>
      <p>Đội ngũ bếp trưởng được đào tạo tại Paris, Tokyo và New York, mang về tinh hoa ẩm thực thế giới và kết hợp khéo léo với nguyên liệu bản địa Việt Nam thuần khiết nhất.</p>
      <div class="about-awards">
        <div class="award"><div class="award-icon">🏆</div><div class="award-text"><strong>Michelin Guide 2023</strong><span>Nhà hàng được khuyên dùng</span></div></div>
        <div class="award"><div class="award-icon">🥇</div><div class="award-text"><strong>Asia's Best 2024</strong><span>Top 50 Restaurants</span></div></div>
        <div class="award"><div class="award-icon">⭐</div><div class="award-text"><strong>Foody Awards</strong><span>Top 10 Fine Dining HN</span></div></div>
        <div class="award"><div class="award-icon">🍷</div><div class="award-text"><strong>Wine Spectator</strong><span>Award of Excellence</span></div></div>
      </div>
    </div>
  </div>
</section>

<!-- RESERVATION -->
<section id="reservation">
  <div class="ornament"><span>Đặt Bàn Trực Tuyến</span></div>
  <div class="res-wrap">
    <div class="res-info">
      <div class="section-eyebrow"><span>Liên Hệ & Đặt Chỗ</span></div>
      <h2 class="section-title">Dành Riêng <em>Bàn Của Bạn</em></h2>
      <p>Hãy để chúng tôi chuẩn bị một buổi tối hoàn hảo — đặt bàn trước để đảm bảo trải nghiệm tốt nhất và nhận những ưu đãi dành riêng cho thực khách.</p>
      <div class="contact-list">
        <div class="contact-row"><div class="contact-icon">📍</div><div class="contact-text"><strong>Địa chỉ</strong><span>87A đường Merlin, Tân Phú, Thủ Đức</span></div></div>
        <div class="contact-row"><div class="contact-icon">🕐</div><div class="contact-text"><strong>Giờ mở cửa</strong><span>Thứ 2 – Chủ Nhật: 8:30 — 23:00</span></div></div>
        <div class="contact-row"><div class="contact-icon">📞</div><div class="contact-text"><strong>Điện thoại</strong><span>(024) 3826 5500 · 0912 345 678</span></div></div>
        <div class="contact-row"><div class="contact-icon">✉️</div><div class="contact-text"><strong>Email</strong><span>hello@vermeil.vn</span></div></div>
      </div>
    </div>
    <div class="res-form-wrap">
      <h3>Đặt Bàn Ngay</h3>
      <p>Điền thông tin · Nhận xác nhận ngay</p>
      
      @if (TempData["Message"] != null)
      {
          <div style="background: rgba(126,205,160,0.1); border: 1px solid #7ecda0; color: #7ecda0; padding: 10px; margin-bottom: 20px; font-size: 0.9rem;">
              @TempData["Message"]
          </div>
      }
      @if (TempData["Error"] != null)
      {
          <div style="background: rgba(224,128,128,0.1); border: 1px solid #e08080; color: #e08080; padding: 10px; margin-bottom: 20px; font-size: 0.9rem;">
              @TempData["Error"]
          </div>
      }

      <form asp-controller="Home" asp-action="BookTable" method="post">
          <div class="form-row">
            <div class="form-group"><label>Họ & Tên</label><input type="text" name="FullName" required placeholder="Nguyễn Văn A"/></div>
            <div class="form-group"><label>Số Điện Thoại</label><input type="tel" name="Phone" required placeholder="0912 345 678"/></div>
          </div>
          <div class="form-row">
            <div class="form-group"><label>Ngày</label><input type="date" name="BookingDate" required/></div>
            <div class="form-group"><label>Giờ</label>
              <select name="BookingTime" required>
                <option value="">— Chọn giờ —</option>
                <option value="08:30">8:30 AM</option>
                <option value="09:00">9:00 AM</option>
                <option value="09:30">9:30 AM</option>
                <option value="10:00">10:00 AM</option>
                <option value="10:30">10:30 AM</option>
                <option value="11:00">11:00 AM</option>
                <option value="11:30">11:30 AM</option>
                <option value="12:00">12:00 PM</option>
                <option value="12:30">12:30 PM</option>
                <option value="13:00">1:00 PM</option>
                <option value="13:30">1:30 PM</option>
                <option value="14:00">2:00 PM</option>
                <option value="14:30">2:30 PM</option>
                <option value="15:00">3:00 PM</option>
                <option value="15:30">3:30 PM</option>
                <option value="16:00">4:00 PM</option>
                <option value="16:30">4:30 PM</option>
                <option value="17:00">5:00 PM</option>
                <option value="17:30">5:30 PM</option>
                <option value="18:00">6:00 PM</option>
                <option value="18:30">6:30 PM</option>
                <option value="19:00">7:00 PM</option>
                <option value="19:30">7:30 PM</option>
                <option value="20:00">8:00 PM</option>
                <option value="20:30">8:30 PM</option>
                <option value="21:00">9:00 PM</option>
                <option value="21:30">9:30 PM</option>
                <option value="22:00">10:00 PM</option>
                <option value="22:30">10:30 PM</option>
                <option value="23:00">11:00 PM</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label>Số Khách</label>
            <select name="GuestCount" required>
              <option value="">— Chọn số khách —</option>
              <option value="1 - 2 người (bàn nhỏ)">1 - 2 người (bàn nhỏ)</option>
              <option value="3 - 4 người (bàn cỡ trung)">3 - 4 người (bàn cỡ trung)</option>
              <option value="5+ người (bàn lớn)">5+ người (bàn lớn)</option>
            </select>
          </div>
          <div class="form-group"><label>Ghi Chú Đặc Biệt</label><textarea name="Note" placeholder="Dị ứng thực phẩm, dịp kỷ niệm, yêu cầu đặc biệt…"></textarea></div>
          <button type="submit" class="form-submit">Xác Nhận Đặt Bàn</button>
      </form>
    </div>
  </div>
</section>

<style>
  /* Cập nhật Kích thước Ảnh Menu (Hình vuông vừa phải) */
  .menu-card-top {
    position: relative;
    width: fit-content;
    margin: 0 auto 12px; /* Giảm khoảng cách dưới ảnh */
    display: flex;
    justify-content: center;
  }
  #menuGrid .menu-icon {
    width: 130px !important; /* Trả lại kích thước vừa phải */
    height: 130px !important;
    border-radius: 10px;
    background: rgba(201,168,76,0.05);
    border: 1px solid rgba(201,168,76,0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    overflow: hidden;
    box-shadow: 0 8px 20px rgba(0,0,0,0.15);
  }
  #menuGrid .menu-badge {
    position: absolute;
    top: -10px; /* Đưa nhãn cao hẳn ra ngoài góc ảnh */
    right: -60px; /* Đưa nhãn ngang hẳn ra ngoài góc ảnh */
    z-index: 10;
    margin: 0;
    transform: scale(0.85);
    box-shadow: 0 4px 10px rgba(0,0,0,0.4); /* Thêm bóng đổ để tách biệt với ảnh */
    pointer-events: none;
  }
  #menuGrid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px; /* Thu hẹp khoảng cách giữa các thẻ món ăn */
    justify-items: center;
    width: 100%;
    margin: 0 auto;
  }
  #menuGrid .menu-card {
    background: rgba(255,255,255,0.015);
    border: 1px solid rgba(255,255,255,0.04);
    padding: 15px;
    border-radius: 12px;
    transition: all 0.4s ease;
    display: flex;
    flex-direction: column;
    height: 100%; /* Đảm bảo thẻ tự động mở rộng theo grid-cell */
    min-width: 280px; 
    max-width: 320px;
  }
  #menuGrid .menu-card:hover {
    background: rgba(255,255,255,0.03);
    transform: translateY(-8px);
    border-color: rgba(201,168,76,0.6);
  }
  #menuGrid .menu-card h4 { margin: 10px 0 5px; font-size: 1.15rem; color: var(--gold); }
  #menuGrid .menu-card p { font-size: 0.85rem; color: var(--text-muted); line-height: 1.4; flex: 1; margin-bottom: 15px; }
  .menu-card-footer { margin-top: auto; padding-top: 10px; border-top: 1px solid rgba(255,255,255,0.05); }
  
  .price-wrap { display: flex; flex-direction: column; }
  .price-old { text-decoration: line-through; color: var(--text-muted); font-size: 0.8rem; margin-bottom: 2px; }
  .price { color: var(--gold); font-weight: 600; font-size: 1.1rem; }

  /* Lọc món ăn hiệu ứng mượt mà */
  .menu-card.hidden {
    display: none;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const tabs = document.querySelectorAll('#menuTabs .tab-btn');
    const grid = document.getElementById('menuGrid');
    
    if (tabs && grid) {
      const cards = grid.querySelectorAll('.menu-card');
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');

          const filter = tab.getAttribute('data-filter');

          cards.forEach(card => {
            if (filter === 'all' || card.getAttribute('data-category') === filter) {
              card.classList.remove('hidden');
            } else {
              card.classList.add('hidden');
            }
          });
        });
      });
    }
  });
</script>
