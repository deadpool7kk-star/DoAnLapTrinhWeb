@page
@model RegisterModel
@{
    ViewData["Title"] = "Đăng Ký Tài Khoản";
    Layout = null; 
}
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"]</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body>
<div class="bg-layer"></div>
<div class="bg-grid"></div>

<div class="corner tl"></div>
<div class="corner tr"></div>
<div class="corner bl"></div>
<div class="corner br"></div>

<div class="side-deco"><span>Admin Portal</span></div>

<div class="login-wrap">
  <div class="login-card">

    <div class="login-logo">
      <span>VERMEIL<sup>®</sup></span>
    </div>
    <div class="login-subtitle">
      <p>Hệ Thống Quản Trị Nội Bộ</p>
    </div>

    <div class="ornament"><span>Đăng Ký</span></div>

    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post">
      <div class="form-group">
        <label asp-for="Input.FullName">Tên Đăng Nhập</label>
        <div class="input-wrap">
          <span class="input-icon">✍️</span>
          <input asp-for="Input.FullName" type="text" placeholder="Nguyễn Văn A" autocomplete="name" aria-required="true" />
        </div>
        <span asp-validation-for="Input.FullName" style="color:#e08080; font-size:0.75rem;"></span>
      </div>

      <div class="form-group">
        <label asp-for="Input.Email">Tài Khoản</label>
        <div class="input-wrap">
          <span class="input-icon">👤</span>
          <input asp-for="Input.Email" type="email" placeholder="admin@vermeil.vn" autocomplete="username" aria-required="true" />
        </div>
        <span asp-validation-for="Input.Email" style="color:#e08080; font-size:0.75rem;"></span>
      </div>

      <div class="form-group">
        <label asp-for="Input.Password">Mật Khẩu</label>
        <div class="input-wrap">
          <span class="input-icon">🔒</span>
          <input asp-for="Input.Password" type="password" placeholder="••••••••••" autocomplete="new-password" aria-required="true" />
        </div>
        <span asp-validation-for="Input.Password" style="color:#e08080; font-size:0.75rem;"></span>
      </div>

      <div class="form-group">
        <label asp-for="Input.ConfirmPassword">Nhập Lại Mật Khẩu</label>
        <div class="input-wrap">
          <span class="input-icon">✔️</span>
          <input asp-for="Input.ConfirmPassword" type="password" placeholder="••••••••••" autocomplete="new-password" aria-required="true" />
        </div>
        <span asp-validation-for="Input.ConfirmPassword" style="color:#e08080; font-size:0.75rem;"></span>
      </div>

      <button id="registerSubmit" type="submit" class="btn-login" style="margin-top: 25px;">Tạo Tài Khoản</button>

      <div class="form-meta" style="justify-content:center; margin-top:15px;">
        <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="forgot-link">Đã có tài khoản? Đăng nhập ngay</a>
      </div>
    </form>

    <div class="login-note">
      Sau khi đăng ký, chờ kích hoạt từ <span>Quản trị viên</span> — Vermeil
    </div>

  </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
