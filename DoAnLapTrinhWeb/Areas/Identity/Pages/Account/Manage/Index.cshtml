@page
@model IndexModel
@{
    ViewData["Title"] = "Profile";
    ViewData["ActivePage"] = ManageNavPages.Index;
}

<div class="identity-form-container">
    <form id="profile-form" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>
        
        <div class="identity-form-group">
            <label asp-for="Username"></label>
            <input asp-for="Username" class="identity-input" disabled />
        </div>

        <div class="identity-form-group">
            <label asp-for="Input.FullName"></label>
            <input asp-for="Input.FullName" class="identity-input" placeholder="Nhập họ và tên..." />
            <span asp-validation-for="Input.FullName" class="field-validation-error"></span>
        </div>

        <div class="identity-form-group">
            <label asp-for="Input.PhoneNumber"></label>
            <input asp-for="Input.PhoneNumber" class="identity-input" placeholder="Nhập số điện thoại..." />
            <span asp-validation-for="Input.PhoneNumber" class="field-validation-error"></span>
        </div>

        <button id="update-profile-button" type="submit" class="btn-identity-save">Lưu Thay Đổi</button>
    </form>
</div>

<style>
    .identity-form-container { max-width: 600px; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
