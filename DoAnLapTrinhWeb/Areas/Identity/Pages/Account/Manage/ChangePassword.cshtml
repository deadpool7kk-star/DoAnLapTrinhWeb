@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change password";
    ViewData["ActivePage"] = ManageNavPages.ChangePassword;
}

<div class="identity-form-container">
    <form id="change-password-form" method="post">
        <div asp-validation-summary="ModelOnly" class="validation-summary-errors" role="alert"></div>
        
        <div class="identity-form-group">
            <label asp-for="Input.OldPassword"></label>
            <input asp-for="Input.OldPassword" class="identity-input" autocomplete="current-password" aria-required="true" placeholder="Nhập mật khẩu hiện tại..." />
            <span asp-validation-for="Input.OldPassword" class="field-validation-error"></span>
        </div>

        <div class="identity-form-group">
            <label asp-for="Input.NewPassword"></label>
            <input asp-for="Input.NewPassword" class="identity-input" autocomplete="new-password" aria-required="true" placeholder="Nhập mật khẩu mới..." />
            <span asp-validation-for="Input.NewPassword" class="field-validation-error"></span>
        </div>

        <div class="identity-form-group">
            <label asp-for="Input.ConfirmPassword"></label>
            <input asp-for="Input.ConfirmPassword" class="identity-input" autocomplete="new-password" aria-required="true" placeholder="Xác nhận mật khẩu mới..." />
            <span asp-validation-for="Input.ConfirmPassword" class="field-validation-error"></span>
        </div>

        <button type="submit" class="btn-identity-save">Cập Nhật Mật Khẩu</button>
    </form>
</div>

<style>
    .identity-form-container { max-width: 600px; }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
