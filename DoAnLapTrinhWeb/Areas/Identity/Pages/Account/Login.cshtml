@page
@model LoginModel

@{
    ViewData["Title"] = "Đăng Nhập Quản Trị";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>@ViewData["Title"]</title>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,700;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
</head>
<body class="login-body">
<div class="bg-layer"></div>
<div class="bg-grid"></div>

<div class="corner tl"></div>
<div class="corner tr"></div>
<div class="corner bl"></div>
<div class="corner br"></div>

<div class="side-deco"><span>Admin Portal</span></div>

<div class="login-wrap">
  <div class="login-card">

    <div class="login-logo">
      <span>VERMEIL<sup>®</sup></span>
    </div>
    <div class="login-subtitle">
      <p>Hệ Thống Quản Trị Nội Bộ</p>
    </div>

    <div class="ornament"><span>Đăng Nhập</span></div>

    <form id="account" method="post">
      <div asp-validation-summary="ModelOnly" class="text-danger" style="color:#e08080; font-size:0.8rem; margin-bottom:15px; text-align:center;" role="alert"></div>
      
      <div class="form-group">
        <label asp-for="Input.Email">Tên Đăng Nhập</label>
        <div class="input-wrap">
          <span class="input-icon">👤</span>
          <input asp-for="Input.Email" type="text" placeholder="admin@vermeil.vn" autocomplete="username" aria-required="true" />
        </div>
        <span asp-validation-for="Input.Email" style="color:#e08080; font-size:0.75rem;"></span>
      </div>

      <div class="form-group">
        <label asp-for="Input.Password">Mật Khẩu</label>
        <div class="input-wrap">
          <span class="input-icon">🔒</span>
          <input asp-for="Input.Password" type="password" placeholder="••••••••••" autocomplete="current-password" aria-required="true" />
        </div>
        <span asp-validation-for="Input.Password" style="color:#e08080; font-size:0.75rem;"></span>
      </div>

      <div class="form-meta">
        <label asp-for="Input.RememberMe" class="checkbox-wrap">
          <input asp-for="Input.RememberMe" type="checkbox"/>
          <span>Ghi nhớ đăng nhập</span>
        </label>
        <a id="forgot-password" asp-page="./ForgotPassword" class="forgot-link">Quên mật khẩu?</a>
      </div>

      <button id="login-submit" type="submit" class="btn-login">Đăng Nhập</button>
    </form>

    <div class="login-note">
      Chỉ dành cho <span>nhân viên được uỷ quyền</span> — Vermeil Fine Dining
    </div>

  </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
<script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>
